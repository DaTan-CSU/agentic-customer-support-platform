# Copy this to .env at the project root. Empty values fall back to whatever
# the backend reads from ~/Desktop/API key.txt at startup.

# Optional: override the location of the keyfile bind-mounted into the
# backend container. Useful on hosts where the file isn't at
# ~/Desktop/API key.txt (e.g. Linux/macOS or non-default profile).
# KEY_FILE_HOST_PATH=/path/to/your/API key.txt

# Aliyun Bailian (image OCR + embeddings). Read by python-backend/ecommerce/vision.py.
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# Tencent Cloud ASR (push-to-talk speech to text). Normally loaded from
# ~/Desktop/API key.txt's "腾讯云密钥" section, but you can override here.
# TENCENTCLOUD_SECRET_ID=AKIDxxxxxxxxxxxxxxxx
# TENCENTCLOUD_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
